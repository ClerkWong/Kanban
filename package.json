{
  "name": "kanban-pwa-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "tsx --test tests/*.test.ts",
    "worker:test": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vitest run --config worker-sync/vitest.config.ts",
    "worker:types": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler types worker-sync/worker-configuration.d.ts -c worker-sync/wrangler.jsonc",
    "worker:types:check": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler types worker-sync/worker-configuration.d.ts --check -c worker-sync/wrangler.jsonc",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "mobile:build": "vite build --config vite.mobile.config.ts",
    "mobile:sync": "pnpm mobile:build && cap sync",
    "mobile:sync:android": "pnpm mobile:build && cap sync android",
    "mobile:sync:ios": "pnpm mobile:build && cap sync ios",
    "mobile:ios": "cap open ios",
    "sync:dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler dev -c worker-sync/wrangler.jsonc",
    "sync:migrate": "pnpm sync:migrate:prod",
    "sync:deploy": "pnpm sync:deploy:prod",
    "sync:migrate:staging": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler d1 migrations apply kanban-sync-staging --remote --env staging -c worker-sync/wrangler.jsonc",
    "sync:deploy:staging": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler deploy --env staging -c worker-sync/wrangler.jsonc",
    "sync:migrate:prod": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler d1 migrations apply kanban-sync --remote -c worker-sync/wrangler.jsonc",
    "sync:deploy:prod": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler deploy --env=\"\" -c worker-sync/wrangler.jsonc",
    "sync:dry-run": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler deploy --dry-run --env=\"\" -c worker-sync/wrangler.jsonc",
    "sync:dry-run:staging": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler deploy --dry-run --env staging -c worker-sync/wrangler.jsonc",
    "sync:smoke": "node scripts/smoke-sync-worker.mjs"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "7.0.1",
    "@capacitor/android": "^8.4.2",
    "@capacitor/camera": "8.2.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/ios": "^8.4.1",
    "capacitor-voice-recorder": "7.0.6",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
